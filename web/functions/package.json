{
  "name": "sagely-functions",
  "version": "0.1.0",
  "description": "Firebase Cloud Functions for Sagely — Mochi agent proxy + future webhooks.",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint --ext .ts src",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "expo-server-sdk": "^6.1.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
