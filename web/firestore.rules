rules_version = '2';

// Firestore security rules for my-todos.
//
// Schema (see core/src/persistence.ts → stateDocPath):
//   users/{uid}/state/{key}
//     • Client-writable keys:  todos, categories, profile,
//                              groceries, groceryGroups (mobile-only)
//     • Function-only key:     agentUsage (admin SDK bypasses rules)
//
// Each user can read AND write only their own subtree. Default deny on
// everything else — including listing the root users collection (which would
// leak the set of valid uids and account count).
//
// Hardening notes:
//   * `key` is restricted to a known whitelist so a malicious client
//     can't spawn arbitrary docs under their state subtree and inflate
//     Firestore costs.
//   * Document shape is validated: only `value` (map) + `updatedAt` (int)
//     are allowed at the top level. This matches the versioned envelope
//     in core/src/persistence.ts and keeps a hostile client from
//     attaching extra fields that downstream code might trust.
//   * Firestore's hard 1 MiB per-doc limit caps total size; we don't
//     re-check byte size here because the rules language doesn't expose
//     a stable byte-size accessor across SDK versions.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid}/state/{key} {
      // Read: any state key including agentUsage so the client can
      // surface remaining-quota UX without a second roundtrip.
      allow read:
        if request.auth != null && request.auth.uid == uid;

      // Write: only the three client-owned keys, only the envelope shape.
      // agentUsage is intentionally absent — only the agentChat Cloud
      // Function (which uses admin credentials) is allowed to mutate it,
      // so a hostile client can't reset its own daily counter.
      //
      // `value` is the serialized `{version,data}` envelope as a JSON
      // string (see core/src/persistence.ts → writeVersioned). Capping
      // its length at 512 KiB stays well under Firestore's hard 1 MiB
      // per-doc limit while bounding what a compromised client can
      // upload in a single write.
      allow write:
        if request.auth != null
        && request.auth.uid == uid
        && key in ['todos', 'categories', 'profile', 'groceries', 'groceryGroups', 'todoReferences']
        && request.resource.data.keys().hasOnly(['value', 'updatedAt'])
        && request.resource.data.value is string
        && request.resource.data.value.size() <= 524288
        && request.resource.data.updatedAt is int;
    }

    // Default deny — explicit so no future "match /{document=**}" elsewhere
    // accidentally exposes data. Required even with allow rules above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
