# Monorepo-wide ignores. Per-package ignores live in web/.gitignore,
# mobile/.gitignore, etc.

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Vite ephemeral cache (sometimes lands at repo root)
.vite/

# Root-level deps: the root package.json holds only the cross-package
# dependency-cruiser arch check. Its node_modules is not committed; the
# lockfile (package-lock.json) is, for reproducible CI installs.
/node_modules/

# Claude Code (user-local state)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Personal icon design WIP (kept locally, not committed). EAS requires
# a clean tree so untracked design variants would block builds.
icons/backup/
icons/turtle-icon-5.jpg
coverage/
